{
  "name": "@mks2508/better-logger",
  "version": "0.18.2-alpha.1",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "Logger avanzado para consola con estilos CSS, temas adaptativos, badges automáticos, SVG, animaciones, CLI integrado y soporte dual browser/terminal con colores ANSI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "types": "./dist/core.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs",
      "types": "./dist/cli-module.d.ts"
    },
    "./transports": {
      "import": "./dist/transports-module.js",
      "require": "./dist/transports-module.cjs",
      "types": "./dist/transports-module.d.ts"
    },
    "./context": {
      "import": "./dist/context-module.js",
      "require": "./dist/context-module.cjs",
      "types": "./dist/context-module.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks-module.js",
      "require": "./dist/hooks-module.cjs",
      "types": "./dist/hooks-module.d.ts"
    },
    "./serializers": {
      "import": "./dist/serializers-module.js",
      "require": "./dist/serializers-module.cjs",
      "types": "./dist/serializers-module.d.ts"
    },
    "./styles": {
      "import": "./dist/styles-module.js",
      "require": "./dist/styles-module.cjs",
      "types": "./dist/styles-module.d.ts"
    },
    "./playground": {
      "import": "./dist/playground-module.js",
      "require": "./dist/playground-module.cjs",
      "types": "./dist/playground-module.d.ts"
    },
    "./node": {
      "import": "./dist/node-module.js",
      "require": "./dist/node-module.cjs",
      "types": "./dist/node-module.d.ts"
    }
  },
  "keywords": [
    "logger",
    "console",
    "styling",
    "css",
    "svg",
    "animation",
    "typescript",
    "browser",
    "cli",
    "debug",
    "consola",
    "registro",
    "terminal",
    "ansi",
    "chalk",
    "server",
    "nodejs",
    "depuración",
    "temas",
    "badges",
    "contexto",
    "componentes"
  ],
  "author": "MKS2508",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MKS2508/advanced-logger.git"
  },
  "bugs": {
    "url": "https://github.com/MKS2508/advanced-logger/issues"
  },
  "homepage": "https://mks2508.github.io/advanced-logger/",
  "scripts": {
    "dev": "vite --config vite.config.demo.ts",
    "demo:dev": "vite --config vite.config.demo.ts",
    "demo:build": "vite build --config vite.config.demo.ts",
    "build": "rolldown --config rolldown.config.ts && tsc --emitDeclarationOnly",
    "build:full": "rolldown --config rolldown.config.ts && tsc --emitDeclarationOnly",
    "build:core": "BUILD_MODE=core rolldown --config rolldown.config.ts && tsc --emitDeclarationOnly --project tsconfig.node.json",
    "build:styling": "BUILD_MODE=styling rolldown --config rolldown.config.ts && tsc --emitDeclarationOnly",
    "build:exports": "BUILD_MODE=exports rolldown --config rolldown.config.ts && tsc --emitDeclarationOnly",
    "build:cli": "BUILD_MODE=cli rolldown --config rolldown.config.ts && tsc --emitDeclarationOnly --project tsconfig.node.json",
    "build:all": "npm run build:full && npm run build:core && npm run build:styling && npm run build:exports && npm run build:cli",
    "clean": "rm -rf dist node_modules/.vite",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "docs:api": "typedoc",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:performance": "bunx vitest bench",
    "test:visual": "bunx vitest run --reporter=visual",
    "test:workflows": "bun tests/test-conflict-resolution.ts",
    "lint:yaml": "yamllint -c .yamllint .github/workflows/",
    "fix:yaml": "./tests/yaml-autofix.sh",
    "validate:workflows": "./tests/validate-workflows.sh",
    "size-limit": "echo 'Checking bundle sizes...' && ls -la dist/",
    "ci:install": "npm ci",
    "ci:build": "npm run build:all",
    "ci:test": "npm run test",
    "ci:publish": "npm publish --access public --ignore-scripts",
    "ci:publish:github": "npm publish --registry=https://npm.pkg.github.com --access public --ignore-scripts",
    "commit:auto": "bun project-utils/commit-generator.ts --auto-approve --quiet",
    "commit:ui": "bun project-utils/commit-ui.ts",
    "version:auto": "bun project-utils/version-manager.ts --auto-approve",
    "version:patch": "bun project-utils/version-manager.ts --type patch --auto-approve",
    "version:minor": "bun project-utils/version-manager.ts --type minor --auto-approve",
    "version:major": "bun project-utils/version-manager.ts --type major --auto-approve",
    "version:alpha": "bun project-utils/version-manager.ts --prefix alpha --auto-approve",
    "version:beta": "bun project-utils/version-manager.ts --prefix beta --auto-approve",
    "version:stable": "bun project-utils/version-manager.ts --prefix '' --auto-approve",
    "release:github": "bun project-utils/github-release-manager.ts --auto-approve",
    "release:full": "npm run version:auto && npm run build:all && npm run release:github && npm run ci:publish",
    "release:auto": "bun project-utils/auto-release-gemini.ts --ai --auto-approve",
    "release:ui": "bun project-utils/auto-release-ui.ts",
    "release:hotfix": "bun project-utils/auto-release-ui.ts --hotfix",
    "release:feature": "bun project-utils/auto-release-ui.ts --feature",
    "release:alpha": "bun project-utils/auto-release-ui.ts --alpha",
    "release:major": "bun project-utils/auto-release-ui.ts --major",
    "workflow:full": "npm run commit:auto && npm run release:full",
    "workflow:commit": "npm run commit:auto",
    "workflow:release": "npm run version:auto && npm run build:all && npm run release:github"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxlint": "^0.11.1",
    "prettier": "^3.4.2",
    "rolldown": "^1.0.0-beta.58",
    "terser": "^5.48.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^2.1.0"
  }
}
